{
  "name": "darkread-proxy",
  "version": "1.0.0",
  "description": "Proxy que converte uma URL em link darkread.io",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "start": "NODE_ENV=production tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "lint": "biome lint --write",
    "format": "biome format --write",
    "biome:check": "biome check --write"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "form-data": "^4.0.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.37",
    "@types/node-fetch": "^2.6.13",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
